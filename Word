<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Barron's SAT Vocabulary — Interactive eBook</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Share+Tech+Mono&family=Noto+Sans+Bengali:wght@400;600;700&display=swap" rel="stylesheet">
<style>
/* ─── THEME VARIABLES ─── */
[data-theme="dark"] {
  --bg:#0d0d0d; --bg2:#161616; --surf:#1c1c1c; --surf2:#242424;
  --border:rgba(255,255,255,0.07); --text:#e2e2e2; --dim:#777;
  --bright:#fff; --acc:#e8d5a3; --acc2:#c9a96e; --acc3:#a07840;
  --card-bg:#1c1c1c; --nav:#0d0d0d; --prog:#e8d5a3;
  --tag-bg:rgba(232,213,163,0.1); --tag:##e8d5a3;
  --shadow:0 8px 32px rgba(0,0,0,0.5); --invert:0;
}
[data-theme="gold"] {
  --bg:#130e00; --bg2:#1c1500; --surf:#251c00; --surf2:#301f00;
  --border:rgba(255,210,0,0.15); --text:#f0dfa0; --dim:#9a7c30;
  --bright:#ffd700; --acc:#ffd700; --acc2:#ffb300; --acc3:#cc8800;
  --card-bg:#251c00; --nav:#130e00; --prog:#ffd700;
  --tag-bg:rgba(255,215,0,0.12); --tag:#ffd700;
  --shadow:0 8px 32px rgba(255,215,0,0.15); --invert:0;
}
[data-theme="cyber"] {
  --bg:#020b18; --bg2:#030f20; --surf:#071524; --surf2:#0b1d30;
  --border:rgba(0,240,195,0.12); --text:#a8cfe0; --dim:#3d7a96;
  --bright:#00f0c3; --acc:#00f0c3; --acc2:#00b8ff; --acc3:#0080cc;
  --card-bg:#071524; --nav:#020b18; --prog:#00f0c3;
  --tag-bg:rgba(0,240,195,0.08); --tag:#00f0c3;
  --shadow:0 8px 32px rgba(0,240,195,0.1); --invert:0;
}
[data-theme="neon"] {
  --bg:#08000f; --bg2:#0f0018; --surf:#130020; --surf2:#1a002d;
  --border:rgba(230,0,255,0.12); --text:#ddb0f5; --dim:#7a3a9a;
  --bright:#e600ff; --acc:#e600ff; --acc2:#ff4dff; --acc3:#aa00cc;
  --card-bg:#130020; --nav:#08000f; --prog:#e600ff;
  --tag-bg:rgba(230,0,255,0.1); --tag:#e600ff;
  --shadow:0 8px 32px rgba(230,0,255,0.15); --invert:0;
}
[data-theme="festive"] {
  --bg:#160800; --bg2:#200c00; --surf:#2c1200; --surf2:#381800;
  --border:rgba(255,130,0,0.15); --text:#ffe0b0; --dim:#aa6020;
  --bright:#ff8c00; --acc:#ff6a00; --acc2:#ffcc00; --acc3:#dd4400;
  --card-bg:#2c1200; --nav:#160800; --prog:#ff6a00;
  --tag-bg:rgba(255,106,0,0.12); --tag:#ff8c00;
  --shadow:0 8px 32px rgba(255,106,0,0.2); --invert:0;
}
[data-theme="paper"] {
  --bg:#f3ede0; --bg2:#e8e0cf; --surf:#fff; --surf2:#faf5ec;
  --border:rgba(0,0,0,0.1); --text:#2a1f0e; --dim:#8c7a60;
  --bright:#1a1000; --acc:#8b4513; --acc2:#a0522d; --acc3:#6b3010;
  --card-bg:#fff; --nav:#f3ede0; --prog:#8b4513;
  --tag-bg:rgba(139,69,19,0.09); --tag:#8b4513;
  --shadow:0 8px 32px rgba(0,0,0,0.12); --invert:1;
}
[data-theme="white"] {
  --bg:#f5f7fb; --bg2:#edf0f7; --surf:#ffffff; --surf2:#f0f4ff;
  --border:rgba(0,0,0,0.07); --text:#1a1e36; --dim:#6c7898;
  --bright:#000; --acc:#2563eb; --acc2:#1d4ed8; --acc3:#1e40af;
  --card-bg:#ffffff; --nav:#ffffff; --prog:#2563eb;
  --tag-bg:rgba(37,99,235,0.07); --tag:#2563eb;
  --shadow:0 8px 32px rgba(37,99,235,0.08); --invert:1;
}

/* ─── BASE ─── */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--bg); color:var(--text);
  font-family:'Poppins',sans-serif; font-size:15px;
  line-height:1.6; min-height:100vh;
  transition:background .35s,color .35s;
}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--bg2)}
::-webkit-scrollbar-thumb{background:var(--acc);border-radius:3px}

/* ─── TOP BAR ─── */
#topbar{
  position:fixed;top:0;left:0;right:0;z-index:200;
  background:var(--nav);backdrop-filter:blur(18px);
  border-bottom:1px solid var(--border);
  padding:8px 20px;display:flex;align-items:center;
  gap:14px;flex-wrap:wrap;
  transition:background .35s;
}
#topbar .brand{
  font-family:'Share Tech Mono';font-size:13px;
  color:var(--acc);letter-spacing:2px;white-space:nowrap;
  margin-right:4px;
}
.ctrl-sep{width:1px;height:22px;background:var(--border);flex-shrink:0}

/* theme dots */
.tdot{
  width:22px;height:22px;border-radius:50%;border:2px solid transparent;
  cursor:pointer;transition:all .2s;flex-shrink:0;
}
.tdot:hover,.tdot.on{border-color:var(--acc);transform:scale(1.2)}
.tdot.on::after{content:'✓';position:absolute;inset:0;display:flex;
  align-items:center;justify-content:center;font-size:10px;
  font-weight:700;color:#fff;text-shadow:0 0 3px #000}
.tdot{position:relative}
.td-dark{background:linear-gradient(135deg,#1c1c1c,#555)}
.td-gold{background:linear-gradient(135deg,#ffd700,#a07000)}
.td-cyber{background:linear-gradient(135deg,#00f0c3,#0088ff)}
.td-neon{background:linear-gradient(135deg,#e600ff,#5500ee)}
.td-festive{background:linear-gradient(135deg,#ff6a00,#ffcc00)}
.td-paper{background:linear-gradient(135deg,#f3ede0,#c8a870);border:1px solid #ccc}
.td-white{background:linear-gradient(135deg,#fff,#c8d8ff);border:1px solid #bbb}

/* search */
#searchbox{
  flex:1;min-width:160px;max-width:280px;
  display:flex;align-items:center;gap:8px;
  background:var(--surf2);border:1px solid var(--border);
  border-radius:24px;padding:5px 14px;
  transition:border-color .2s;
}
#searchbox:focus-within{border-color:var(--acc)}
#searchbox input{
  background:none;border:none;outline:none;
  color:var(--text);font-family:'Poppins';font-size:13px;width:100%;
}
#searchbox input::placeholder{color:var(--dim)}
#searchbox span{color:var(--dim);font-size:14px}

/* mode tabs */
.mtab{
  padding:5px 14px;border-radius:20px;font-size:12px;
  font-weight:600;letter-spacing:1px;cursor:pointer;
  border:1px solid var(--border);color:var(--dim);
  background:transparent;font-family:'Poppins';
  transition:all .2s;white-space:nowrap;
}
.mtab:hover{border-color:var(--acc);color:var(--acc)}
.mtab.on{background:var(--acc);color:var(--bg);border-color:var(--acc)}

/* progress */
#prog-bar{
  position:fixed;top:0;left:0;height:3px;
  background:linear-gradient(90deg,var(--acc),var(--acc2));
  z-index:201;transition:width .12s;
}

/* ─── LAYOUT ─── */
#wrap{max-width:1060px;margin:0 auto;padding:72px 16px 60px}

/* ─── HERO COVER ─── */
#cover{
  min-height:340px;
  background:linear-gradient(135deg,var(--surf2),var(--surf));
  border:1px solid var(--border);border-radius:18px;
  padding:48px 44px;margin-bottom:28px;
  position:relative;overflow:hidden;
  box-shadow:var(--shadow);
  display:flex;flex-direction:column;justify-content:center;
}
#cover::before{
  content:'';position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(var(--acc-rgb,.5,.5,.5),0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(var(--acc-rgb,.5,.5,.5),0.03) 1px,transparent 1px);
  background-size:36px 36px;pointer-events:none;
}
.cover-eyebrow{
  font-family:'Share Tech Mono';font-size:11px;
  letter-spacing:4px;color:var(--acc);text-transform:uppercase;
  margin-bottom:14px;opacity:.8;
}
.cover-h1{
  font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;
  color:var(--bright);line-height:1.15;margin-bottom:10px;
}
.cover-h1 span{color:var(--acc)}
.cover-sub{font-size:14px;color:var(--dim);max-width:460px;margin-bottom:28px}
.cover-stats{display:flex;gap:24px;flex-wrap:wrap}
.cstat{
  display:flex;flex-direction:column;gap:2px;
  padding:14px 20px;background:var(--bg);
  border:1px solid var(--border);border-radius:10px;
  min-width:110px;transition:border-color .2s;
}
.cstat:hover{border-color:var(--acc)}
.cstat-val{
  font-family:'Share Tech Mono';font-size:1.5rem;
  font-weight:700;color:var(--acc);
}
.cstat-lbl{font-size:11px;color:var(--dim);letter-spacing:1px}

/* ─── ALPHABET NAV ─── */
#alpha-nav{
  display:flex;flex-wrap:wrap;gap:5px;
  margin-bottom:20px;
}
.al-btn{
  width:32px;height:32px;border-radius:6px;
  font-size:12px;font-weight:700;cursor:pointer;
  border:1px solid var(--border);background:var(--surf);
  color:var(--dim);transition:all .15s;
  display:flex;align-items:center;justify-content:center;
  font-family:'Share Tech Mono';
}
.al-btn:hover,.al-btn.on{
  background:var(--acc);color:var(--bg);
  border-color:var(--acc);transform:scale(1.05);
}
.al-btn.empty{opacity:.25;pointer-events:none}

/* ─── FILTER ROW ─── */
#filter-row{
  display:flex;align-items:center;gap:10px;
  margin-bottom:20px;flex-wrap:wrap;
}
.fcount{
  font-family:'Share Tech Mono';font-size:12px;
  color:var(--dim);margin-left:auto;
}

/* ─── WORD GRID ─── */
#word-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:14px;
}

/* ─── WORD CARD ─── */
.wcard{
  background:var(--card-bg);
  border:1px solid var(--border);
  border-radius:12px;padding:18px 20px;
  cursor:pointer;position:relative;overflow:hidden;
  transition:transform .2s,border-color .2s,box-shadow .2s;
  display:flex;flex-direction:column;gap:8px;
}
.wcard::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--acc),var(--acc2));
  transform:scaleX(0);transform-origin:left;transition:transform .25s;
}
.wcard:hover{
  transform:translateY(-3px);border-color:var(--acc);
  box-shadow:var(--shadow);
}
.wcard:hover::after{transform:scaleX(1)}
.wcard.starred .star-btn{color:var(--acc)}

.wcard-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
.wnum{
  font-family:'Share Tech Mono';font-size:10px;
  color:var(--dim);letter-spacing:2px;
}
.wword{
  font-size:1.15rem;font-weight:700;color:var(--bright);
  letter-spacing:.3px;flex:1;
}
.star-btn{
  background:none;border:none;cursor:pointer;
  font-size:16px;color:var(--dim);transition:color .2s,transform .2s;
  flex-shrink:0;padding:0;line-height:1;
}
.star-btn:hover{color:var(--acc);transform:scale(1.2)}

.wen{
  font-size:12.5px;color:var(--dim);
  font-style:italic;line-height:1.45;
}
.wbn{
  font-family:'Noto Sans Bengali','Poppins',sans-serif;
  font-size:13.5px;color:var(--acc);font-weight:600;
}
.wex{
  font-size:12px;color:var(--dim);
  background:var(--surf2);padding:8px 12px;
  border-radius:6px;border-left:2px solid var(--acc);
  line-height:1.5;margin-top:4px;
}
.wtags{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.wtag{
  padding:3px 10px;border-radius:12px;
  font-size:11px;font-weight:600;
  background:var(--tag-bg);color:var(--acc);
  border:1px solid var(--acc);opacity:.85;
}

/* ─── FLIP CARD (flashcard mode) ─── */
#flashcard-wrap{
  display:none;
  flex-direction:column;align-items:center;gap:24px;
  padding:20px 0;
}
.fc-progress{
  font-family:'Share Tech Mono';font-size:13px;
  color:var(--dim);letter-spacing:2px;
}
.fc-scene{
  width:100%;max-width:520px;height:280px;
  perspective:1000px;cursor:pointer;
}
.fc-card{
  width:100%;height:100%;position:relative;
  transform-style:preserve-3d;transition:transform .5s;
}
.fc-card.flipped{transform:rotateY(180deg)}
.fc-front,.fc-back{
  position:absolute;inset:0;
  backface-visibility:hidden;
  border-radius:18px;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:36px;text-align:center;
  border:1px solid var(--border);
  background:var(--surf);box-shadow:var(--shadow);
}
.fc-back{transform:rotateY(180deg);background:var(--surf2)}
.fc-label{
  font-family:'Share Tech Mono';font-size:10px;
  letter-spacing:4px;color:var(--dim);margin-bottom:16px;
}
.fc-word{font-size:2.2rem;font-weight:800;color:var(--bright)}
.fc-bn{
  font-family:'Noto Sans Bengali','Poppins',sans-serif;
  font-size:1.4rem;color:var(--acc);font-weight:700;
  margin-bottom:10px;
}
.fc-en{font-size:14px;color:var(--dim);max-width:360px}
.fc-ex{
  font-size:12.5px;color:var(--dim);font-style:italic;
  background:var(--bg);padding:10px 16px;border-radius:8px;
  margin-top:12px;border-left:2px solid var(--acc);
}
.fc-hint{font-size:11px;color:var(--dim);letter-spacing:2px;margin-top:10px}
.fc-nav{display:flex;gap:14px;align-items:center}
.fc-btn{
  padding:10px 28px;border-radius:24px;
  border:1px solid var(--border);background:var(--surf);
  color:var(--text);font-family:'Poppins';font-size:13px;
  font-weight:600;cursor:pointer;transition:all .2s;
}
.fc-btn:hover,.fc-btn.primary{
  background:var(--acc);color:var(--bg);border-color:var(--acc);
}
.fc-btn:disabled{opacity:.3;pointer-events:none}
.fc-shuffle{
  padding:8px 18px;border-radius:20px;
  border:1px solid var(--border);background:var(--surf);
  color:var(--dim);font-family:'Share Tech Mono';font-size:11px;
  cursor:pointer;transition:all .2s;letter-spacing:1px;
}
.fc-shuffle:hover{border-color:var(--acc);color:var(--acc)}

/* ─── QUIZ MODE ─── */
#quiz-wrap{display:none;flex-direction:column;align-items:center;gap:20px;padding:20px 0}
.qz-panel{width:100%;max-width:560px}
.qz-header{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:18px;
}
.qz-score{font-family:'Share Tech Mono';font-size:13px;color:var(--acc)}
.qz-question{
  background:var(--surf);border:1px solid var(--border);
  border-radius:14px;padding:28px 32px;margin-bottom:16px;
  box-shadow:var(--shadow);
}
.qz-qtype{
  font-family:'Share Tech Mono';font-size:10px;
  color:var(--dim);letter-spacing:3px;margin-bottom:12px;
}
.qz-qword{font-size:1.8rem;font-weight:800;color:var(--bright);margin-bottom:8px}
.qz-qsub{font-size:14px;color:var(--dim);font-style:italic}
.qz-options{display:flex;flex-direction:column;gap:10px}
.qz-opt{
  padding:14px 20px;border-radius:10px;
  border:1px solid var(--border);background:var(--surf);
  color:var(--text);font-size:14px;font-weight:500;
  cursor:pointer;transition:all .2s;text-align:left;
  font-family:'Poppins';
}
.qz-opt:hover:not(:disabled){
  border-color:var(--acc);background:var(--surf2);
}
.qz-opt.correct{border-color:#22c55e;background:rgba(34,197,94,.12);color:#22c55e}
.qz-opt.wrong{border-color:#ef4444;background:rgba(239,68,68,.12);color:#ef4444}
.qz-opt:disabled{cursor:default}
.qz-feedback{
  padding:14px 20px;border-radius:10px;
  font-size:14px;font-weight:600;margin-top:6px;
  display:none;
}
.qz-feedback.show{display:block}
.qz-feedback.ok{background:rgba(34,197,94,.1);color:#22c55e;border:1px solid #22c55e}
.qz-feedback.bad{background:rgba(239,68,68,.1);color:#ef4444;border:1px solid #ef4444}
.qz-next{
  width:100%;padding:13px;border-radius:10px;
  border:none;background:var(--acc);color:var(--bg);
  font-family:'Poppins';font-size:14px;font-weight:700;
  cursor:pointer;transition:opacity .2s;letter-spacing:1px;
  margin-top:10px;display:none;
}
.qz-next.show{display:block}
.qz-result{
  width:100%;max-width:480px;
  background:var(--surf);border:1px solid var(--border);
  border-radius:16px;padding:40px;text-align:center;
  box-shadow:var(--shadow);display:none;
}
.qz-result.show{display:block}
.qz-result-score{
  font-family:'Share Tech Mono';font-size:3rem;
  color:var(--acc);font-weight:700;margin:16px 0;
}
.qz-result-lbl{font-size:14px;color:var(--dim)}
.qz-restart{
  padding:12px 32px;border-radius:24px;
  background:var(--acc);color:var(--bg);
  border:none;font-family:'Poppins';font-size:14px;
  font-weight:700;cursor:pointer;margin-top:20px;
  transition:opacity .2s;
}
.qz-restart:hover{opacity:.85}

/* ─── STARRED VIEW ─── */
#starred-empty{
  display:none;text-align:center;padding:60px;
  color:var(--dim);font-size:15px;
}

/* ─── EMPTY STATE ─── */
#empty-state{
  display:none;text-align:center;padding:60px;
  color:var(--dim);font-size:15px;grid-column:1/-1;
}

/* ─── BACK TO TOP ─── */
#btt{
  position:fixed;bottom:24px;right:24px;
  width:42px;height:42px;border-radius:50%;
  background:var(--acc);color:var(--bg);
  border:none;font-size:18px;cursor:pointer;
  opacity:0;pointer-events:none;
  transition:all .3s;box-shadow:0 4px 18px rgba(0,0,0,.3);
  z-index:190;display:flex;align-items:center;justify-content:center;
}
#btt.vis{opacity:1;pointer-events:all}
#btt:hover{transform:scale(1.1) translateY(-2px)}

/* ─── MODAL (word detail) ─── */
#modal-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.65);z-index:300;
  backdrop-filter:blur(6px);
  align-items:center;justify-content:center;padding:16px;
}
#modal-overlay.open{display:flex}
#modal{
  background:var(--surf);border:1px solid var(--border);
  border-radius:16px;width:min(520px,100%);
  padding:32px;position:relative;
  box-shadow:0 0 60px rgba(0,0,0,.4);
  animation:popIn .25s ease both;
}
@keyframes popIn{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
#modal-close{
  position:absolute;top:14px;right:14px;
  background:none;border:1px solid var(--border);
  color:var(--dim);width:30px;height:30px;
  border-radius:6px;cursor:pointer;font-size:16px;
  transition:all .2s;
}
#modal-close:hover{border-color:#ef4444;color:#ef4444}
.modal-num{font-family:'Share Tech Mono';font-size:11px;color:var(--dim);letter-spacing:3px;margin-bottom:8px}
.modal-word{font-size:2.2rem;font-weight:800;color:var(--bright);margin-bottom:6px}
.modal-en{font-size:14px;color:var(--dim);font-style:italic;margin-bottom:16px;line-height:1.6}
.modal-bn-label{font-family:'Share Tech Mono';font-size:10px;color:var(--dim);letter-spacing:3px;margin-bottom:6px;text-transform:uppercase}
.modal-bn{
  font-family:'Noto Sans Bengali','Poppins',sans-serif;
  font-size:1.3rem;color:var(--acc);font-weight:700;
  margin-bottom:20px;
}
.modal-ex-label{font-family:'Share Tech Mono';font-size:10px;color:var(--dim);letter-spacing:3px;margin-bottom:6px;text-transform:uppercase}
.modal-ex{
  background:var(--surf2);border-radius:8px;
  border-left:3px solid var(--acc);padding:14px 16px;
  font-size:14px;color:var(--text);line-height:1.6;font-style:italic;
}
.modal-actions{display:flex;gap:10px;margin-top:20px;justify-content:flex-end}
.modal-star{
  padding:8px 20px;border-radius:20px;
  border:1px solid var(--acc);color:var(--acc);
  background:transparent;font-family:'Poppins';font-size:13px;
  font-weight:600;cursor:pointer;transition:all .2s;
}
.modal-star:hover,.modal-star.on{background:var(--acc);color:var(--bg)}
.modal-nav-btn{
  padding:8px 18px;border-radius:20px;
  border:1px solid var(--border);color:var(--dim);
  background:transparent;font-family:'Poppins';font-size:13px;
  cursor:pointer;transition:all .2s;
}
.modal-nav-btn:hover{border-color:var(--acc);color:var(--acc)}

/* ─── RESPONSIVE ─── */
