/* ════ STATE ════ */
let starred = new Set(JSON.parse(localStorage.getItem('sat-starred')||'[]'));
let currentMode = 'browse';
let currentFilter = 'all';
let searchQ = '';
let activeAlpha = '';
let quizTotal = parseInt(localStorage.getItem('sat-quizzed')||'0');
let fcIndex = 0;
let fcList = [...WORDS];
let fcStarredOnly = false;
let qzIndex = 0;
let qzScore = 0;
let qzAnswered = false;
let qzCorrectWord = '';
let modalIndex = -1;

/* ════ SAVE ════ */
function saveStarred(){
  localStorage.setItem('sat-starred', JSON.stringify([...starred]));
  document.getElementById('c-starred').textContent = starred.size;
}
function saveQuizzed(n){
  quizTotal = n;
  localStorage.setItem('sat-quizzed', n);
  document.getElementById('c-quiz').textContent = n;
}

/* ════ INIT ════ */
function init(){
  document.getElementById('c-starred').textContent = starred.size;
  document.getElementById('c-quiz').textContent = quizTotal;
  buildAlphaNav();
  renderWords();
}

/* ════ ALPHABET NAV ════ */
function buildAlphaNav(){
  const nav = document.getElementById('alpha-nav');
  const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
  const available = new Set(WORDS.map(w=>w.word[0].toUpperCase()));
  nav.innerHTML = letters.map(l=>`
    <button class="al-btn ${!available.has(l)?'empty':''}" onclick="setAlpha('${l}',this)">${l}</button>
  `).join('');
}

function setAlpha(l, btn){
  if(activeAlpha===l){ activeAlpha=''; document.querySelectorAll('.al-btn').forEach(b=>b.classList.remove('on')); }
  else {
    activeAlpha=l;
    document.querySelectorAll('.al-btn').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on');
  }
  renderWords();
}

/* ════ FILTER ════ */
function setFilter(f, btn){
  currentFilter = f;
  document.querySelectorAll('#filter-row .mtab').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  renderWords();
}

/* ════ SEARCH ════ */
function applySearch(q){
  searchQ = q.toLowerCase().trim();
  activeAlpha = '';
  document.querySelectorAll('.al-btn').forEach(b=>b.classList.remove('on'));
  renderWords();
  // switch to browse if not there
  if(currentMode!=='browse'){
    setMode('browse', document.querySelector('[data-mode="browse"]'));
  }
}

/* ════ FILTERED LIST ════ */
function getFiltered(){
  let list = WORDS;
  if(currentFilter==='starred') list = list.filter(w=>starred.has(w.sl));
  if(activeAlpha) list = list.filter(w=>w.word[0].toUpperCase()===activeAlpha);
  if(searchQ) list = list.filter(w=>
    w.word.toLowerCase().includes(searchQ) ||
    w.bn.includes(searchQ) ||
    (EN[w.word]||'').toLowerCase().includes(searchQ)
  );
  return list;
}

/* ════ RENDER WORDS ════ */
function renderWords(){
  const grid = document.getElementById('word-grid');
  const empty = document.getElementById('empty-state');
  const fcount = document.getElementById('fc-count');
  const list = getFiltered();
  fcount.textContent = list.length + ' word' + (list.length!==1?'s':'');

  // starred empty
  const se = document.getElementById('starred-empty');
  if(currentMode==='starred'){
    if(starred.size===0){ se.style.display='block'; grid.innerHTML=''; return; }
    se.style.display='none';
  } else { se.style.display='none'; }

  if(list.length===0){
    empty.style.display='block'; grid.innerHTML=''; return;
  }
  empty.style.display='none';

  grid.innerHTML = list.map((w,i)=>{
    const en = EN[w.word]||'';
    const isStarred = starred.has(w.sl);
    return `<div class="wcard ${isStarred?'starred':''}"
      onclick="openModal(${w.sl})"
      style="animation-delay:${Math.min(i*.03,0.5)}s">
      <div class="wcard-top">
        <div>
          <div class="wnum">#${String(w.sl).padStart(3,'0')}</div>
          <div class="wword">${w.word}</div>
        </div>
        <button class="star-btn" onclick="event.stopPropagation();toggleStar(${w.sl},this)">${isStarred?'★':'☆'}</button>
      </div>
      ${en?`<div class="wen">${en}</div>`:''}
      <div class="wbn">${w.bn}</div>
      <div class="wex">${w.ex}</div>
    </div>`;
  }).join('');
}

/* ════ STAR ════ */
function toggleStar(sl, btn){
  if(starred.has(sl)){ starred.delete(sl); btn.textContent='☆'; btn.closest('.wcard').classList.remove('starred'); }
  else { starred.add(sl); btn.textContent='★'; btn.closest('.wcard').classList.add('starred'); }
  saveStarred();
  if(currentFilter==='starred'||currentMode==='starred') renderWords();
}

/* ════ MODAL ════ */
function openModal(sl){
  const w = WORDS.find(x=>x.sl===sl);
  if(!w)return;
  modalIndex = WORDS.indexOf(w);
  fillModal(w);
  document.getElementById('modal-overlay').classList.add('open');
}
function fillModal(w){
  document.getElementById('m-num').textContent = '#'+String(w.sl).padStart(3,'0');
  document.getElementById('m-word').textContent = w.word;
  document.getElementById('m-en').textContent = EN[w.word]||'';
  document.getElementById('m-bn').textContent = w.bn;
  document.getElementById('m-ex').textContent = w.ex;
  const s = document.getElementById('m-star');
  if(starred.has(w.sl)){ s.textContent='★ Starred'; s.classList.add('on'); }
  else { s.textContent='☆ Star'; s.classList.remove('on'); }
}
function toggleModalStar(){
  const w = WORDS[modalIndex];
  if(!w)return;
  const s = document.getElementById('m-star');
  if(starred.has(w.sl)){ starred.delete(w.sl); s.textContent='☆ Star'; s.classList.remove('on'); }
  else { starred.add(w.sl); s.textContent='★ Starred'; s.classList.add('on'); }
  saveStarred();
  renderWords();
}
function modalNav(dir){
  const list = getFiltered();
  const curW = WORDS[modalIndex];
  const pos = list.findIndex(x=>x.sl===curW.sl);
  const next = list[(pos+dir+list.length)%list.length];
  if(next){ modalIndex=WORDS.indexOf(next); fillModal(next); }
}
function closeModalDirect(){ document.getElementById('modal-overlay').classList.remove('open'); }
function closeModal(e){ if(e.target===document.getElementById('modal-overlay')) closeModalDirect(); }

/* ════ MODE ════ */
function setMode(mode, btn){
  currentMode = mode;
  document.querySelectorAll('.mtab[data-mode]').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('browse-wrap').style.display='none';
  document.getElementById('flashcard-wrap').style.display='none';
  document.getElementById('quiz-wrap').style.display='none';
  document.getElementById('starred-empty').style.display='none';

  if(mode==='browse'){ document.getElementById('browse-wrap').style.display='block'; renderWords(); }
  else if(mode==='flash'){ document.getElementById('flashcard-wrap').style.display='flex'; initFlash(); }
  else if(mode==='quiz'){ document.getElementById('quiz-wrap').style.display='flex'; startQuiz(); }
  else if(mode==='starred'){
    document.getElementById('browse-wrap').style.display='block';
    currentFilter='starred';
    document.querySelectorAll('#filter-row .mtab').forEach(b=>b.classList.remove('on'));
    document.querySelector('#filter-row .mtab').classList.remove('on');
    renderWords();
  }
}

/* ════ FLASHCARD ════ */
function initFlash(){
  fcList = fcStarredOnly ? WORDS.filter(w=>starred.has(w.sl)) : [...WORDS];
  if(fcList.length===0) fcList=[...WORDS];
  fcIndex=0;
  renderFlash();
}
function renderFlash(){
  const w = fcList[fcIndex];
  document.getElementById('fc-card').classList.remove('flipped');
  document.getElementById('fc-word').textContent = w.word;
  document.getElementById('fc-bn').textContent = w.bn;
  document.getElementById('fc-en').textContent = EN[w.word]||'';
  document.getElementById('fc-ex').textContent = w.ex;
  document.getElementById('fc-prog').textContent = `${fcIndex+1} / ${fcList.length}`;
  document.getElementById('fc-prev').disabled = fcIndex===0;
}
function flipCard(){ document.getElementById('fc-card').classList.toggle('flipped'); }
function fcNav(dir){
  fcIndex = (fcIndex+dir+fcList.length)%fcList.length;
  renderFlash();
}
function shuffleFlash(){
  fcList.sort(()=>Math.random()-.5); fcIndex=0; renderFlash();
}
function resetFlash(){ fcIndex=0; renderFlash(); }
function starredOnlyFlash(){
  fcStarredOnly=!fcStarredOnly;
  document.getElementById('fc-star-toggle').style.opacity=fcStarredOnly?.5:1;
  initFlash();
}

/* ════ QUIZ ════ */
let qzList=[];
function startQuiz(){
  qzList = [...WORDS].sort(()=>Math.random()-.5).slice(0,20);
  qzIndex=0; qzScore=0; qzAnswered=false;
  document.getElementById('qz-result').classList.remove('show');
  document.getElementById('qz-question-block').style.display='block';
  document.getElementById('qz-next').classList.remove('show');
  document.getElementById('qz-feedback').classList.remove('show');
  document.getElementById('qz-score').textContent='0 / 0';
  renderQuestion();
}
function renderQuestion(){
  if(qzIndex>=qzList.length){ endQuiz(); return; }
  qzAnswered=false;
  const w = qzList[qzIndex];
  qzCorrectWord = w.word;
  document.getElementById('qz-next').classList.remove('show');
  document.getElementById('qz-feedback').classList.remove('show','ok','bad');
  document.getElementById('qz-score').textContent = qzScore + ' / ' + qzIndex;

  // random question type
  const type = Math.random()<.5 ? 'en2bn' : 'bn2en';
  if(type==='en2bn'){
    document.getElementById('qz-qtype').textContent = 'WHAT IS THE BENGALI MEANING?';
    document.getElementById('qz-qword').textContent = w.word;
    document.getElementById('qz-qsub').textContent = EN[w.word]||'';
    // options: 4 Bengali meanings
    const pool = WORDS.filter(x=>x.sl!==w.sl).sort(()=>Math.random()-.5).slice(0,3);
    const opts = [w.bn, ...pool.map(x=>x.bn)].sort(()=>Math.random()-.5);
    renderOpts(opts, w.bn, false);
  } else {
    document.getElementById('qz-qtype').textContent = 'WHICH WORD MATCHES THIS MEANING?';
    document.getElementById('qz-qword').textContent = w.bn;
    document.getElementById('qz-qsub').textContent = w.ex;
    const pool = WORDS.filter(x=>x.sl!==w.sl).sort(()=>Math.random()-.5).slice(0,3);
    const opts = [w.word, ...pool.map(x=>x.word)].sort(()=>Math.random()-.5);
    renderOpts(opts, w.word, true);
  }
}
function renderOpts(opts, correct, isWord){
  const cont = document.getElementById('qz-opts');
  cont.innerHTML = opts.map(o=>`
    <button class="qz-opt" onclick="answerQ('${o.replace(/'/g,"\\'")}','${correct.replace(/'/g,"\\'")}',this)">
      ${isWord?o:`<span style="font-family:'Noto Sans Bengali','Poppins',sans-serif">${o}</span>`}
    </button>`).join('');
}
function answerQ(chosen, correct, btn){
  if(qzAnswered)return;
  qzAnswered=true;
  const opts = document.querySelectorAll('.qz-opt');
  opts.forEach(b=>b.disabled=true);
  const fb = document.getElementById('qz-feedback');
  if(chosen===correct){
    btn.classList.add('correct'); qzScore++;
    fb.textContent='✓ Correct! "'+correct+'"'; fb.className='qz-feedback show ok';
  } else {
    btn.classList.add('wrong');
    opts.forEach(b=>{ if(b.textContent.trim()===correct||b.innerHTML.includes(correct)) b.classList.add('correct'); });
    fb.textContent='✗ Wrong. Correct: "'+correct+'"'; fb.className='qz-feedback show bad';
  }
  document.getElementById('qz-score').textContent = qzScore + ' / ' + (qzIndex+1);
  document.getElementById('qz-next').classList.add('show');
  saveQuizzed(quizTotal+1);
}
function nextQuestion(){ qzIndex++; renderQuestion(); }
function endQuiz(){
  document.getElementById('qz-question-block').style.display='none';
  const pct = Math.round(qzScore/qzList.length*100);
  document.getElementById('qz-final-score').textContent = qzScore+'/'+qzList.length;
  document.getElementById('qz-result-lbl').textContent = pct>=80?'Excellent! 🔥':pct>=60?'Good job! 👍':'Keep practicing! 💪';
  document.getElementById('qz-result').classList.add('show');
}

/* ════ THEME ════ */
function setTheme(t, btn){
  document.body.setAttribute('data-theme',t);
  document.querySelectorAll('.tdot').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  localStorage.setItem('sat-theme',t);
}

/* ════ READING PROGRESS ════ */
window.addEventListener('scroll',()=>{
  const s=window.scrollY, h=document.documentElement.scrollHeight-window.innerHeight;
  document.getElementById('prog-bar').style.width=(h>0?s/h*100:0)+'%';
  document.getElementById('btt').classList.toggle('vis',s>300);
});

/* ════ KEYBOARD ════ */
document.addEventListener('keydown',e=>{
  if(document.getElementById('modal-overlay').classList.contains('open')){
    if(e.key==='Escape') closeModalDirect();
    if(e.key==='ArrowRight') modalNav(1);
    if(e.key==='ArrowLeft') modalNav(-1);
  }
  if(currentMode==='flash'){
    if(e.key==='ArrowRight'||e.key==='l') fcNav(1);
    if(e.key==='ArrowLeft'||e.key==='j') fcNav(-1);
    if(e.key===' '||e.key==='f') flipCard();
  }
});

/* ════ RESTORE PREFS ════ */
window.addEventListener('DOMContentLoaded',()=>{
  const t=localStorage.getItem('sat-theme')||'dark';
  document.body.setAttribute('data-theme',t);
  document.querySelectorAll('.tdot').forEach(b=>{
    if(b.getAttribute('onclick').includes("'"+t+"'")) b.classList.add('on');
    else b.classList.remove('on');
  });
  init();
});
</script>
